{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "mesh_name",
    "units",
    "pivot",
    "primitives",
    "notes"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "mesh_name": {
      "type": "string",
      "minLength": 1
    },
    "units": {
      "type": "string",
      "enum": [
        "cm"
      ]
    },
    "pivot": {
      "type": "string",
      "enum": [
        "base_center",
        "center"
      ]
    },
    "notes": {
      "type": "string"
    },
    "primitives": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "type",
          "transform",
          "width",
          "depth",
          "height",
          "radius",
          "segments",
          "steps"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "box",
              "plane",
              "cylinder",
              "cone",
              "ramp",
              "stair"
            ]
          },
          "transform": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "location_cm",
              "rotation_deg",
              "scale"
            ],
            "properties": {
              "location_cm": {
                "$ref": "#/$defs/vector3"
              },
              "rotation_deg": {
                "$ref": "#/$defs/vector3"
              },
              "scale": {
                "$ref": "#/$defs/vector3Positive"
              }
            }
          },
          "width": {
            "type": "number",
            "minimum": 0
          },
          "depth": {
            "type": "number",
            "minimum": 0
          },
          "height": {
            "type": "number",
            "minimum": 0
          },
          "radius": {
            "type": "number",
            "minimum": 0
          },
          "segments": {
            "type": "integer",
            "minimum": 0,
            "maximum": 128
          },
          "steps": {
            "type": "integer",
            "minimum": 0,
            "maximum": 32
          }
        }
      }
    }
  },
  "$defs": {
    "vector3": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      }
    },
    "vector3Positive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "y": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "z": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
