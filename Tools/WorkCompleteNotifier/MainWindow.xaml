<Window x:Class="WorkCompleteNotifier.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        Foreground="#FFF4F8FB"
        Loaded="Window_Loaded"
        PreviewMouseDown="CloseOnPreviewMouseDown"
        PreviewTouchDown="CloseOnPreviewTouchDown">
    <Window.Resources>
        <SolidColorBrush x:Key="OverlayCardBrush" Color="#FF102532" />
        <SolidColorBrush x:Key="SectionBrush" Color="#FF173444" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF6BE3AC" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FF94B3C2" />
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SectionBrush}" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="24" />
        </Style>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SectionValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFF4F8FB" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="40" Background="Transparent">
        <Border Width="980"
                Padding="44"
                CornerRadius="32"
                Background="{StaticResource OverlayCardBrush}"
                BorderBrush="#294E6776"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="TASK COMPLETE"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="Bahnschrift"
                           FontSize="18"
                           FontWeight="SemiBold" />

                <StackPanel Grid.Row="1" Margin="0,18,0,0">
                    <TextBlock Text="{Binding Title}"
                               FontFamily="Bahnschrift"
                               FontSize="46"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="작업이 종료되었습니다. 아무 곳이나 클릭하면 닫힙니다."
                               Margin="0,10,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               FontFamily="Bahnschrift"
                               FontSize="20"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,30,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="완료 시각" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding CompletedAtDisplay}"
                                       Margin="0,12,0,0"
                                       Style="{StaticResource SectionValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="수행 시간" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding DurationDisplay}"
                                       Margin="0,12,0,0"
                                       Style="{StaticResource SectionValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Style="{StaticResource SectionCardStyle}"
                            Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="작업 경로" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding WorkPath}"
                                       Margin="0,12,0,0"
                                       FontFamily="Cascadia Mono"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="3"
                           Margin="0,28,0,0"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource MutedBrush}"
                           FontFamily="Bahnschrift"
                           FontSize="16"
                           Text="Click anywhere to dismiss" />
            </Grid>
        </Border>
    </Grid>
</Window>
